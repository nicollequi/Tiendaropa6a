@{
    ViewData["Title"] = "Inicio";
}

<!-- HERO -->
<section style="background: linear-gradient(135deg, #1a1a2e 0%, #0f3460 60%, #e2b96f 100%); min-height: 90vh; display: flex; align-items: center;">
    <div class="container text-center text-white py-5">
        <p style="color: #e2b96f; letter-spacing: 4px; text-transform: uppercase; font-size: 0.9rem;">Bienvenido al</p>
        <h1 style="font-family: 'Playfair Display', serif; font-size: 4rem; font-weight: 700; margin: 1rem 0;">
            Sistema de Gestión<br><span style="color: #e2b96f;">Tienda Ropa</span>
        </h1>
        <p style="font-size: 1.2rem; color: #ccc; max-width: 600px; margin: 0 auto 2rem;">
            Administra tu inventario, categorías y productos de manera elegante y eficiente.
        </p>
        <div class="d-flex gap-3 justify-content-center flex-wrap">
            <a asp-controller="Producto" asp-action="Index" class="btn-gold btn">
                <i class="fas fa-tshirt"></i> Ver Productos
            </a>
            <a asp-controller="Producto" asp-action="Create" class="btn btn-dark-custom">
                <i class="fas fa-plus"></i> Agregar Producto
            </a>
        </div>
    </div>
</section>

<!-- STATS -->
<section class="container py-5">
    <div class="row g-4 text-center">
        <div class="col-md-4">
            <div class="card p-4">
                <i class="fas fa-tshirt fa-3x mb-3" style="color: #e2b96f;"></i>
                <h3 style="font-family: 'Playfair Display', serif;">Productos</h3>
                <p class="text-muted">Gestiona todas las prendas de tu tienda</p>
                <a asp-controller="Producto" asp-action="Index" class="btn-gold btn mt-2">Ver productos</a>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card p-4">
                <i class="fas fa-tags fa-3x mb-3" style="color: #0f3460;"></i>
                <h3 style="font-family: 'Playfair Display', serif;">Categorías</h3>
                <p class="text-muted">Organiza tus prendas por tipo o colección</p>
                <a asp-controller="Categoria" asp-action="Index" class="btn-dark-custom btn mt-2">Ver categorías</a>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card p-4">
                <i class="fas fa-chart-bar fa-3x mb-3" style="color: #e2b96f;"></i>
                <h3 style="font-family: 'Playfair Display', serif;">Inventario</h3>
                <p class="text-muted">Controla el stock y valor de tu inventario</p>
                <a asp-controller="Producto" asp-action="Index" class="btn-gold btn mt-2">Ver inventario</a>
            </div>
        </div>
    </div>
</section>

<!-- CARACTERISTICAS -->
<section style="background: #f0f4ff; padding: 4rem 0;">
    <div class="container">
        <h2 class="text-center mb-5" style="font-family: 'Playfair Display', serif; color: #1a1a2e;">
            ¿Por qué usar nuestro sistema?
        </h2>
        <div class="row g-4">
            <div class="col-md-3 text-center">
                <i class="fas fa-bolt fa-2x mb-3" style="color: #e2b96f;"></i>
                <h5>Rápido</h5>
                <p class="text-muted small">Gestiona productos en segundos</p>
            </div>
            <div class="col-md-3 text-center">
                <i class="fas fa-shield-alt fa-2x mb-3" style="color: #0f3460;"></i>
                <h5>Seguro</h5>
                <p class="text-muted small">Control de acceso por roles</p>
            </div>
            <div class="col-md-3 text-center">
                <i class="fas fa-mobile-alt fa-2x mb-3" style="color: #e2b96f;"></i>
                <h5>Responsive</h5>
                <p class="text-muted small">Funciona en cualquier dispositivo</p>
            </div>
            <div class="col-md-3 text-center">
                <i class="fas fa-chart-line fa-2x mb-3" style="color: #0f3460;"></i>
                <h5>Control total</h5>
                <p class="text-muted small">Stock, precios y categorías</p>
            </div>
        </div>
    </div>
</section>