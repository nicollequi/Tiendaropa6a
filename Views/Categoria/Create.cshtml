@model TiendaRopa.Models.Categoria
@{
    ViewData["Title"] = "Nueva Categoría";
}

<div class="page-header">
    <div class="container">
        <h1><i class="fas fa-plus"></i> Nueva Categoría</h1>
        <p class="mb-0" style="color:#ccc;">Completa los datos para crear una categoría</p>
    </div>
</div>

<div class="container pb-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card p-4">
                <form asp-action="Create">
                    <div class="mb-3">
                        <label asp-for="Nombre" class="form-label fw-bold">Nombre</label>
                        <input asp-for="Nombre" class="form-control" placeholder="Ej: Camisas" />
                        <span asp-validation-for="Nombre" class="text-danger small"></span>
                    </div>
                    <div class="mb-4">
                        <label asp-for="Descripcion" class="form-label fw-bold">Descripción</label>
                        <textarea asp-for="Descripcion" class="form-control" rows="3" placeholder="Describe esta categoría..."></textarea>
                    </div>
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn-gold btn">
                            <i class="fas fa-save"></i> Guardar
                        </button>
                        <a asp-action="Index" class="btn btn-dark-custom">
                            <i class="fas fa-arrow-left"></i> Cancelar
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>