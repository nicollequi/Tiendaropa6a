@model List<TiendaRopa.Models.Categoria>
@{
    ViewData["Title"] = "Categorías";
}

<div class="page-header">
    <div class="container d-flex justify-content-between align-items-center">
        <div>
            <h1><i class="fas fa-tags"></i> Categorías</h1>
            <p class="mb-0" style="color:#ccc;">Gestiona las categorías de tus prendas</p>
        </div>
        <a asp-action="Create" class="btn-gold btn">
            <i class="fas fa-plus"></i> Nueva Categoría
        </a>
    </div>
</div>

<div class="container pb-5">
    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <i class="fas fa-tags fa-4x mb-3" style="color:#e2b96f;"></i>
            <h4>No hay categorías aún</h4>
            <p class="text-muted">Crea tu primera categoría para organizar los productos</p>
            <a asp-action="Create" class="btn-gold btn mt-2">
                <i class="fas fa-plus"></i> Crear categoría
            </a>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var categoria in Model)
            {
                <div class="col-md-4">
                    <div class="card p-4">
                        <div class="d-flex align-items-center mb-3">
                            <div style="background:linear-gradient(135deg,#1a1a2e,#0f3460);width:50px;height:50px;border-radius:50%;display:flex;align-items:center;justify-content:center;margin-right:1rem;">
                                <i class="fas fa-tag" style="color:#e2b96f;"></i>
                            </div>
                            <h5 class="mb-0" style="font-family:'Playfair Display',serif;">@categoria.Nombre</h5>
                        </div>
                        <p class="text-muted small mb-3">@(categoria.Descripcion ?? "Sin descripción")</p>
                        <div class="d-flex gap-2">
                            <a asp-action="Edit" asp-route-id="@categoria.Id" class="btn btn-sm btn-dark-custom">
                                <i class="fas fa-edit"></i> Editar
                            </a>
                            <a asp-action="Delete" asp-route-id="@categoria.Id" class="btn btn-sm btn-danger" style="border-radius:25px;">
                                <i class="fas fa-trash"></i> Eliminar
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>