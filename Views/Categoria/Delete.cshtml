@model TiendaRopa.Models.Categoria
@{
    ViewData["Title"] = "Eliminar Categoría";
}

<div class="page-header">
    <div class="container">
        <h1><i class="fas fa-trash"></i> Eliminar Categoría</h1>
    </div>
</div>

<div class="container pb-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card p-4 text-center">
                <i class="fas fa-exclamation-triangle fa-3x mb-3" style="color:#e2b96f;"></i>
                <h4>¿Estás segura?</h4>
                <p class="text-muted">Vas a eliminar la categoría <strong>@Model.Nombre</strong>. Esta acción no se puede deshacer.</p>
                <form asp-action="Delete">
                    <input type="hidden" asp-for="Id" />
                    <div class="d-flex gap-2 justify-content-center mt-3">
                        <button type="submit" class="btn btn-danger" style="border-radius:25px;">
                            <i class="fas fa-trash"></i> Sí, eliminar
                        </button>
                        <a asp-action="Index" class="btn btn-dark-custom">
                            <i class="fas fa-arrow-left"></i> Cancelar
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>