@model TiendaRopa.Models.Usuario
@{
    ViewData["Title"] = "Registro";
}

<div style="min-height:100vh; background:linear-gradient(135deg,#1a1a2e 0%,#0f3460 60%,#e2b96f 100%); display:flex; align-items:center; justify-content:center; padding:2rem 0;">
    <div style="background:white; border-radius:20px; padding:3rem; width:100%; max-width:450px; box-shadow:0 20px 60px rgba(0,0,0,0.3);">

        <div class="text-center mb-4">
            <h1 style="font-family:'Playfair Display',serif; color:#1a1a2e; font-size:2rem;">👗 TiendaRopa</h1>
            <p style="color:#888; font-size:0.9rem; letter-spacing:2px; text-transform:uppercase;">Crear cuenta</p>
        </div>

        @if (ViewBag.Error != null)
        {
            <div class="alert alert-danger" style="border-radius:10px; font-size:0.9rem;">
                <i class="fas fa-exclamation-circle"></i> @ViewBag.Error
            </div>
        }

        <form asp-action="Registro" method="post">
            <div class="mb-3">
                <label asp-for="Nombre" class="form-label fw-bold" style="color:#1a1a2e;">Nombre completo</label>
                <input asp-for="Nombre" class="form-control" placeholder="Tu nombre"
                       style="border-radius:10px; padding:0.8rem;" />
                <span asp-validation-for="Nombre" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Email" class="form-label fw-bold" style="color:#1a1a2e;">Correo electrónico</label>
                <input asp-for="Email" class="form-control" placeholder="tucorreo@email.com"
                       style="border-radius:10px; padding:0.8rem;" />
                <span asp-validation-for="Email" class="text-danger small"></span>
            </div>
            <div class="mb-4">
                <label asp-for="Contrasena" class="form-label fw-bold" style="color:#1a1a2e;">Contraseña</label>
                <input asp-for="Contrasena" type="password" class="form-control" placeholder="••••••••"
                       style="border-radius:10px; padding:0.8rem;" />
                <span asp-validation-for="Contrasena" class="text-danger small"></span>
            </div>
            <button type="submit" class="btn-gold btn w-100" style="padding:0.8rem;">
                <i class="fas fa-user-plus"></i> Crear cuenta
            </button>
        </form>

        <hr class="my-4">
        <p class="text-center text-muted small">
            ¿Ya tienes cuenta?
            <a asp-action="Login" style="color:#e2b96f; font-weight:700;">Inicia sesión</a>
        </p>
    </div>
</div>